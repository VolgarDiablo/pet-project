generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  name          String
  password      String
  emailVerified Boolean  @default(false)
  metaData      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
